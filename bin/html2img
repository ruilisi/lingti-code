#!/usr/bin/env bash
# html2img — Convert an HTML file to an image (default: PNG)
#
# Usage:
#   html2img <input.html> [output.png]
#   html2img <input.html> -o <output.png>
#   html2img <input.html> --width 1200
#   html2img <input.html> --format jpg
#
# Options:
#   -o, --output  Output file path (default: same dir as input, .png/.jpg)
#   --width       Viewport width  (default: 1200)
#   --format      Image format: png | jpg  (default: png)
#   -h, --help    Show this help
#
# Captures the full page height automatically using Puppeteer.

set -euo pipefail

PUPPETEER_MODULE="/Users/alex/.nvm/versions/node/v24.13.0/lib/node_modules/puppeteer"

usage() {
  sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
  exit 0
}

die() { echo "html2img: error: $*" >&2; exit 1; }

[[ -d "$PUPPETEER_MODULE" ]] || die "Puppeteer not found at: $PUPPETEER_MODULE"

# ── Argument parsing ──────────────────────────────────────
INPUT=""
OUTPUT=""
WIDTH=1200
FORMAT="png"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)    usage ;;
    -o|--output)  OUTPUT="$2"; shift 2 ;;
    --width)      WIDTH="$2";  shift 2 ;;
    --format)     FORMAT="$2"; shift 2 ;;
    --height)     shift 2 ;;  # ignored — full page height is auto-detected
    -*)           die "unknown option: $1" ;;
    *)
      if [[ -z "$INPUT" ]]; then INPUT="$1"
      elif [[ -z "$OUTPUT" ]]; then OUTPUT="$1"
      else die "unexpected argument: $1"
      fi
      shift ;;
  esac
done

[[ -z "$INPUT" ]] && { usage; }
[[ -f "$INPUT" ]] || die "file not found: $INPUT"

# Normalise format
FORMAT="$(echo "$FORMAT" | tr '[:upper:]' '[:lower:]')"
[[ "$FORMAT" == "jpg" ]] && FORMAT="jpeg"
[[ "$FORMAT" == "jpeg" || "$FORMAT" == "png" ]] || die "unsupported format: $FORMAT (use png or jpg)"

OUT_EXT="png"; [[ "$FORMAT" == "jpeg" ]] && OUT_EXT="jpg"

# Derive output path
if [[ -z "$OUTPUT" ]]; then
  OUTPUT="${INPUT%.*}.${OUT_EXT}"
fi

ABS_INPUT="$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")"
mkdir -p "$(dirname "$OUTPUT")"
ABS_OUTPUT="$(cd "$(dirname "$OUTPUT")" && pwd)/$(basename "$OUTPUT")"

# ── Capture via Puppeteer ─────────────────────────────────
node - "$ABS_INPUT" "$ABS_OUTPUT" "$WIDTH" "$FORMAT" "$PUPPETEER_MODULE" <<'EOF'
const [,, inputPath, outputPath, width, format, modulePath] = process.argv;

(async () => {
  const puppeteer = require(modulePath);
  const browser = await puppeteer.launch({
    headless: true,
    args: ['--no-sandbox', '--disable-dev-shm-usage'],
  });
  const page = await browser.newPage();

  await page.setViewport({ width: parseInt(width), height: 800 });
  await page.goto(`file://${inputPath}`, { waitUntil: 'networkidle0', timeout: 30000 });

  // Wait for fonts/images to settle
  await new Promise(r => setTimeout(r, 500));

  await page.screenshot({
    path: outputPath,
    fullPage: true,
    type: format === 'jpeg' ? 'jpeg' : 'png',
    ...(format === 'jpeg' ? { quality: 90 } : {}),
  });

  await browser.close();
})().catch(e => { console.error(e); process.exit(1); });
EOF

SIZE="$(du -sh "$ABS_OUTPUT" | cut -f1)"
echo "Saved → $ABS_OUTPUT  ($SIZE)"
